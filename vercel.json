{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install --frozen-lockfile",
  "functions": {
    "src/app/api/**/route.ts": {
      "maxDuration": 10
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "altfaze.com"
        }
      ],
      "destination": "https://altfaze.in/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.altfaze.com"
        }
      ],
      "destination": "https://altfaze.in/:path*",
      "permanent": true
    }
  ]
}
