# ==================== DATABASE ====================
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/altfaze"

# ==================== NEXTAUTH ====================
# Generate a secret: `openssl rand -base64 32`
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl"
NEXTAUTH_URL="https://altfaze.in"

# ==================== APPLICATION ====================
NEXT_PUBLIC_APP_NAME="ALTFaze"
NEXT_PUBLIC_APP_DOMAIN="altfaze.in"
NEXT_PUBLIC_SITE_URL="https://altfaze.in"
NEXT_PUBLIC_CANONICAL_DOMAIN="altfaze.in"
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# ==================== DEFAULT ADMIN ====================
DEFAULT_ADMIN_EMAIL="admin@altfaze.in"
DEFAULT_ADMIN_PASSWORD="change-this-password"
DEFAULT_ADMIN_NAME="ALTFaze Admin"

# ==================== PAYMENTS ====================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# ==================== CLOUDINARY ====================
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# ==================== OAUTH (Optional) ====================
# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ==================== EMAIL (Optional - For Notifications) ====================
RESEND_API_KEY="your-resend-api-key"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
