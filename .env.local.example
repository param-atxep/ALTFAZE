# ALTFaze Local Development Environment Configuration
# Copy this file to .env.local and fill in your values

# ==================== DATABASE ====================
# PostgreSQL connection string
# Default for local dev: postgresql://postgres:password@localhost:5432/altfaze
DATABASE_URL="postgresql://postgres:password@localhost:5432/altfaze"

# ==================== ENVIRONMENT ====================
# Must be: development, production, or test
NODE_ENV="development"

# ==================== NEXTAUTH ====================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-generated-secret-here-at-least-32-chars-random"
# Local development URL
NEXTAUTH_URL="http://localhost:3000"

# ==================== APPLICATION ====================
# Public variables (visible in browser)
NEXT_PUBLIC_APP_NAME="ALTFaze"
NEXT_PUBLIC_APP_DOMAIN="localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_CANONICAL_DOMAIN="localhost"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ==================== PAYMENTS ====================
# Stripe (use test keys from dashboard.stripe.com)
STRIPE_SECRET_KEY="sk_test_your_test_key_here"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_test_key_here"
STRIPE_WEBHOOK_SECRET="whsec_test_webhook_secret_here"

# Razorpay (use test keys from dashboard.razorpay.com)
RAZORPAY_KEY_ID="rzp_test_your_test_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_secret_here"
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_your_test_key_id"

# ==================== FILE UPLOAD ====================
# Cloudinary - Get from cloudinary.com dashboard
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# ==================== AUTHENTICATION PROVIDERS ====================
# Google OAuth (optional - get from Google Cloud Console)
# Leave empty to skip Google login
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth (optional - get from GitHub Settings)
# Leave empty to skip GitHub login
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ==================== ANALYTICS ====================
# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=""

# ==================== NOTIFICATIONS & EMAIL ====================
# Resend Email Service (optional)
RESEND_API_KEY=""

# Or use SMTP instead
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# ==================== ADMIN SETUP ====================
# Initial admin user (set up on first run)
DEFAULT_ADMIN_EMAIL="admin@example.com"
DEFAULT_ADMIN_PASSWORD="change-this-password-immediately"
DEFAULT_ADMIN_NAME="Admin"

# ==================== DEVELOPMENT FLAGS ====================
# Enable detailed logging
DEBUG="altfaze:*"

# Skip email sending in development (test only)
SKIP_EMAIL="false"
